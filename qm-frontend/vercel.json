{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://api-gateway-REPLACE_ME.onrender.com/api/:path*"
    },
    {
      "source": "/auth/:path*",
      "destination": "https://api-gateway-REPLACE_ME.onrender.com/auth/:path*"
    },
    {
      "source": "/login/:path*",
      "destination": "https://api-gateway-REPLACE_ME.onrender.com/login/:path*"
    },
    {
      "source": "/oauth2/:path*",
      "destination": "https://api-gateway-REPLACE_ME.onrender.com/oauth2/:path*"
    }
  ]
}
