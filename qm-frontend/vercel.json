{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://api-gateway-qk46.onrender.com/api/$1"
    },
    {
      "source": "/auth/(.*)",
      "destination": "https://api-gateway-qk46.onrender.com/auth/$1"
    },
    {
      "source": "/login/(.*)",
      "destination": "https://api-gateway-qk46.onrender.com/login/$1"
    },
    {
      "source": "/oauth2/(.*)",
      "destination": "https://api-gateway-qk46.onrender.com/oauth2/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}