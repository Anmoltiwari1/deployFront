{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://your-api-gateway-url.onrender.com/api/:path*"
    },
    {
      "source": "/auth/:path*",
      "destination": "https://your-api-gateway-url.onrender.com/auth/:path*"
    },
    {
      "source": "/login/:path*",
      "destination": "https://your-api-gateway-url.onrender.com/login/:path*"
    }
  ]
}
